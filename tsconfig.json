{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2023",

    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "incremental": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}